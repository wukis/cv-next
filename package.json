{
  "name": "tailwindui-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.7.0",
  "engines": {
    "node": ">=24 <26",
    "npm": ">=11 <12"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc -p tsconfig.quality.json --noEmit",
    "quality": "npm run format:check && npm run lint && npm run typecheck && npm run typecheck:strict && npm run knip && npm run build",
    "knip": "knip",
    "prepare": "husky",
    "cv:pdf": "npx playwright install chromium && npm run build && node scripts/generate-cv-pdf.mjs",
    "cv:pdf:ensure-staged": "node scripts/ensure-cv-pdf-staged.mjs",
    "linkedin:import": "tsx scripts/linkedin-sync.ts import",
    "linkedin:sync": "tsx scripts/linkedin-sync.ts sync",
    "linkedin:accept": "tsx scripts/linkedin-sync.ts accept",
    "linkedin:restore": "tsx scripts/linkedin-sync.ts restore"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,mjs,cjs,json,css,md,mdx,yml,yaml}": [
      "prettier --write"
    ],
    "**/*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix"
    ]
  },
  "browserslist": "defaults, not ie <= 11",
  "dependencies": {
    "@sentry/nextjs": "^10.43.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "clsx": "^2.1.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "adm-zip": "^0.5.16",
    "csv-parse": "^6.1.0",
    "eslint": "^10.1.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "knip": "^6.1.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.57.1"
  }
}
