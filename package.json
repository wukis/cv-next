{
  "name": "tailwindui-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.7.0",
  "engines": {
    "node": ">=24 <26",
    "npm": ">=11 <12"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/obfuscate.mjs",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc -p tsconfig.quality.json --noEmit",
    "quality": "npm run format:check && npm run lint && npm run typecheck && npm run build",
    "knip": "knip",
    "prepare": "husky",
    "cv:pdf": "npx playwright install chromium && npm run build && node scripts/generate-cv-pdf.mjs",
    "linkedin:import": "tsx scripts/linkedin-sync.ts import",
    "linkedin:sync": "tsx scripts/linkedin-sync.ts sync",
    "linkedin:accept": "tsx scripts/linkedin-sync.ts accept",
    "linkedin:restore": "tsx scripts/linkedin-sync.ts restore"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,mjs,cjs,json,css,md,mdx,yml,yaml}": [
      "prettier --write"
    ],
    "**/*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix"
    ]
  },
  "browserslist": "defaults, not ie <= 11",
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.1.1",
    "@sentry/nextjs": "^10.32.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20.19.27",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@types/webpack-env": "^1.18.1",
    "autoprefixer": "^10.4.23",
    "cheerio": "^1.1.2",
    "clsx": "^2.1.0",
    "fast-glob": "^3.2.11",
    "feed": "^4.2.2",
    "next": "^16.1.1",
    "next-themes": "^0.4.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "remark-gfm": "^4.0.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "adm-zip": "^0.5.16",
    "csv-parse": "^6.1.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "javascript-obfuscator": "^5.2.1",
    "knip": "^5.87.0",
    "lint-staged": "^16.4.0",
    "mdx": "^0.3.1",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.57.0"
  }
}
